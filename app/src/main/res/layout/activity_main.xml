<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_editor_screen"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        style="@style/Widget.DrawingApp.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:subtitle="@string/app_tagline"
        app:title="@string/app_name" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.DrawingApp.HeroCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_medium"
        android:layout_marginTop="@dimen/margin_tiny">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hero_label"
                android:textColor="@color/brand_secondary"
                android:textSize="@dimen/text_small"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:text="@string/editor_headline"
                android:textColor="@color/ink_strong"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_tiny"
                android:lineSpacingExtra="2dp"
                android:text="@string/editor_subtitle"
                android:textColor="@color/ink_soft"
                android:textSize="@dimen/text_body" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                app:singleLine="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCurrentMode"
                    style="@style/Widget.DrawingApp.StatusChip"
                    android:text="@string/draw_mode" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCurrentShape"
                    style="@style/Widget.DrawingApp.StatusChip"
                    android:text="@string/rectangle_tool" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCurrentStyle"
                    style="@style/Widget.DrawingApp.StatusChip"
                    android:text="@string/stroke_value_placeholder" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSelectionState"
                    style="@style/Widget.DrawingApp.StatusChip"
                    android:text="@string/selection_inactive" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_small"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/margin_medium">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.DrawingApp.SectionCard"
                android:layout_width="@dimen/control_panel_width"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/panel_shapes_title"
                        android:textColor="@color/ink_strong"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_tiny"
                        android:text="@string/panel_shapes_subtitle"
                        android:textColor="@color/ink_soft"
                        android:textSize="@dimen/text_small" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/shapeToggleGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLine"
                            style="@style/Widget.DrawingApp.ToggleButton"
                            android:contentDescription="@string/draw_line_description"
                            android:text="@string/line_tool" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRect"
                            style="@style/Widget.DrawingApp.ToggleButton"
                            android:contentDescription="@string/draw_rectangle_description"
                            android:text="@string/rectangle_tool" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOval"
                            style="@style/Widget.DrawingApp.ToggleButton"
                            android:contentDescription="@string/draw_ellipse_description"
                            android:text="@string/ellipse_tool" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.DrawingApp.SectionCard"
                android:layout_width="@dimen/control_panel_width"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_small">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/panel_modes_title"
                        android:textColor="@color/ink_strong"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_tiny"
                        android:text="@string/panel_modes_subtitle"
                        android:textColor="@color/ink_soft"
                        android:textSize="@dimen/text_small" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/modeToggleGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDrawMode"
                            style="@style/Widget.DrawingApp.ToggleButton"
                            android:contentDescription="@string/draw_mode_description"
                            android:text="@string/draw_mode" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectMode"
                            style="@style/Widget.DrawingApp.ToggleButton"
                            android:contentDescription="@string/select_mode_description"
                            android:text="@string/select_mode" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEraseMode"
                            style="@style/Widget.DrawingApp.ToggleButton"
                            android:contentDescription="@string/erase_mode_description"
                            android:text="@string/erase_mode" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.DrawingApp.SectionCard"
                android:layout_width="@dimen/control_panel_width"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/panel_actions_title"
                        android:textColor="@color/ink_strong"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_tiny"
                        android:text="@string/panel_actions_subtitle"
                        android:textColor="@color/ink_soft"
                        android:textSize="@dimen/text_small" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUndo"
                            style="@style/Widget.DrawingApp.ActionGridButton.Secondary"
                            android:contentDescription="@string/undo_description"
                            android:text="@string/undo_action" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDelete"
                            style="@style/Widget.DrawingApp.ActionGridButton.Destructive"
                            android:contentDescription="@string/delete_description"
                            android:text="@string/delete_action" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClear"
                            style="@style/Widget.DrawingApp.ActionGridButton.Secondary"
                            android:contentDescription="@string/clear_description"
                            android:text="@string/clear_action" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShare"
                            style="@style/Widget.DrawingApp.ActionGridButton.Primary"
                            android:contentDescription="@string/share_description"
                            android:text="@string/share_action" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </HorizontalScrollView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.DrawingApp.SectionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_medium"
        android:layout_marginTop="@dimen/margin_small">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/panel_style_title"
                android:textColor="@color/ink_strong"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_tiny"
                android:text="@string/panel_style_subtitle"
                android:textColor="@color/ink_soft"
                android:textSize="@dimen/text_small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_small"
                    android:text="@string/color_target_label"
                    android:textColor="@color/ink_strong"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/targetToggleGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStrokeTarget"
                        style="@style/Widget.DrawingApp.ToggleButton"
                        android:text="@string/stroke_target" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFillTarget"
                        style="@style/Widget.DrawingApp.ToggleButton"
                        android:text="@string/fill_target" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNoFill"
                    style="@style/Widget.DrawingApp.InlineButton.Secondary"
                    android:layout_marginStart="@dimen/margin_small"
                    android:text="@string/no_fill_action" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stroke_label"
                    android:textColor="@color/ink_strong"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStrokeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_small"
                    android:text="@string/stroke_value_placeholder"
                    android:textColor="@color/brand_primary"
                    android:textSize="@dimen/text_medium"
                    android:textStyle="bold" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBarStroke"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:contentDescription="@string/stroke_seekbar_description"
                android:max="24"
                android:min="1"
                android:progress="8"
                android:progressTint="@color/brand_primary"
                android:thumbTint="@color/brand_accent" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/paletteContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_medium"
        android:layout_marginTop="@dimen/margin_small"
        android:text="@string/status_draw_mode"
        android:textColor="@color/ink_soft"
        android:textSize="@dimen/text_small" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.DrawingApp.CanvasCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="@dimen/margin_medium"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/canvas_panel_title"
                android:textColor="@color/ink_strong"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_tiny"
                android:text="@string/canvas_panel_subtitle"
                android:textColor="@color/ink_soft"
                android:textSize="@dimen/text_small" />

            <mg.ramat.drawingapp.views.DrawingView
                android:id="@+id/drawingView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/margin_medium"
                android:layout_weight="1"
                android:background="@color/canvas_background"
                android:contentDescription="@string/drawing_canvas_description"
                android:minHeight="@dimen/canvas_min_height" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
